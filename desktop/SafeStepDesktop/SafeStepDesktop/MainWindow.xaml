<Window x:Class="SafeStepDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SafeStepDesktop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Connection bar at the top -->
        <StackPanel Grid.Row="0"
 Orientation="Horizontal"
 Margin="0,0,0,10">
            <TextBlock Text="COM Port:"
 VerticalAlignment="Center"
 Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbPorts"
 Width="120" Margin="0,0,10,0"/>
            <Button x:Name="btnRefresh"
 Content="Refresh"
 Click="BtnRefresh_Click"
 Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbBaudRate"
 Width="100" Margin="0,0,10,0"/>
            <Button x:Name="btnConnect"
 Content="Connect"
 Click="BtnConnect_Click"
 Margin="0,0,5,0"/>
            <Button x:Name="btnDisconnect"
 Content="Disconnect"
 Click="BtnDisconnect_Click"
 IsEnabled="False"/>
        </StackPanel>
        <!-- Status bar at the bottom -->
        <StatusBar Grid.Row="2">
            <TextBlock x:Name="txtStatus"
 Text="Disconnected"/>
        </StatusBar>
    </Grid>
</Window>
